{
  "name": "@studio/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Studio client SPA — docking shell: panel rails, workspace routing, StudioSocket, silent layout persistence",
  "author": "Tucker <connect@tucker.sh>",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
