{
  "name": "@studio/contract",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared TypeScript contracts for Studio — each capability owns its modules; consumers import, never redeclare",
  "author": "Tucker <connect@tucker.sh>",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  }
}
